# JWT secret shared between services
JWT_SECRET_KEY=shared-secret-key-change-in-prod

# Database (shared by task-service and analytics-service)
DB_NAME=taskmanager_db
DB_USER=taskmanager_user
DB_PASSWORD=taskmanager_password

# Default admin account (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Debug mode (set to 0 in production)
DEBUG=1

# Frontend API URLs
VITE_API_URL=http://localhost:8000
VITE_ANALYTICS_URL=http://localhost:8001
